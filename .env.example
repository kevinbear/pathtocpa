# PathToCPA — optional Supabase cloud sync.
# The app works fully WITHOUT these (local-only mode). Set them to enable
# accounts + cross-device sync. Copy this file to `.env.local` and fill in
# your project's values from: Supabase dashboard → Connect → Project URL & API keys.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
